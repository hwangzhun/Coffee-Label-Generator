{
  "name": "coffee-card-editor",
  "version": "1.1.2",
  "description": "咖啡名片批量编辑器",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "serve": "parcel serve index.html --port 3000",
    "clean": "rimraf dist .parcel-cache",
    "build": "parcel build index.html --dist-dir dist",
    "build:static": "node scripts/copy-static-dist.js",
    "copy:dist": "node scripts/copy-dist-extras.js",
    "build:prod": "npm run clean && npm run build && npm run copy:dist",
    "build:prod:static": "npm run clean && npm run build:static && npm run copy:dist"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "dotenv": "^16.6.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@parcel/optimizer-css": "^2.16.0",
    "@parcel/optimizer-htmlnano": "^2.16.0",
    "@parcel/optimizer-terser": "^2.16.0",
    "nodemon": "^3.0.1",
    "parcel": "^2.16.0",
    "rimraf": "^5.0.5"
  },
  "keywords": [
    "coffee",
    "card",
    "editor",
    "pdf",
    "batch"
  ],
  "author": "Coffee Card Editor",
  "license": "MIT"
}
