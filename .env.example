# 复制本文件为 .env 后填写真实值（不要提交 .env 到仓库）

# 运行环境：development 时启用开发相关行为（如 server.js 中的判断）
NODE_ENV=development

# 腾讯云 COS（server-cos.js 签名 URL）
# 在控制台「访问管理 - API 密钥」创建 SecretId / SecretKey
COS_SECRET_ID=your_secret_id_here
COS_SECRET_KEY=your_secret_key_here

# 存储桶与地域（与控制台一致；以下为项目内默认值）
COS_BUCKET=blog-data-1306368489
COS_REGION=ap-guangzhou

# 预签名 URL 有效期（秒），默认 3600
COS_EXPIRES=3600
